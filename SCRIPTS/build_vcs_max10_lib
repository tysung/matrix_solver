#!/bin/bash -x
#
# Compile Altera Max10 devices VHDL Lib using VCS simulator
#
#
export QUARTUS_INSTALL_DIR=/nas/projects/FPGA_tools/tools/linux/altera/23.1_std/quartus
#export VCS_HOME=/export/tools/synopsys/vcs/V-2023.12-SP2-2-T-20240913
#export VCS_HOME=/export/tools/synopsys/L-2016.06-SP1
export VCS_HOME=/export/tools/synopsys/vcs/Q-2020.03
export VERDI_HOME=/export/tools/synopsys/vc_static/R-2020.12/verdi
export PATH=$VCS_HOME/bin:$PATH
#
REPO_DIR=/nas/home/tsung/CODE/cift-internal_062325
WORKDIR=/nas/home/tsung/MAX10_VCS_BRAM
RTLDIR=$WORKDIR/files
LIBDIR=$WORKDIR/libraries_max10
#
# compile verdi flag - "-kdb"
DBG=-kdb
RUN_DBG=-verdi
#
SKIP_DEV_COM=0
SKIP_COM=0
SKIP_ELAB=0
SKIP_SIM=0
#
#which vhdlan
#
# ----------------------------------------
# overwrite variables - DO NOT MODIFY!
# This block evaluates each command line argument, typically used for 
# overwriting variables. An example usage:
#   ./run_vcs_lib SKIP_DEV_COM=0 SKIP_ELAB=0 SKIP_SIM=1
#
for expression in "$@"; do
  eval $expression
  if [ $? -ne 0 ]; then
    echo "Error: This command line argument, \"$expression\", is/has an invalid expression." >&2
    exit $?
  fi
done
#
# Generating VCS simulation models for VHDL Lib for ALL(inc Fourteennm) devices defined in Quartus Prime
#
# compile device library files
cd $WORKDIR
if [ $SKIP_DEV_COM -eq 0 ]; then
  #rm -rf $LIBDIR 
  mkdir -p $LIBDIR 
  #rm -rf $LIBDIR/../libraries
  ln -sf $LIBDIR ./libraries
  # default command didn't compile with -full64 which is a problem
  #quartus_sh --simlib_comp -family stratix10 -tool vcsmx -tool_path $VCS_HOME/bin -language vhdl -directory ./libraries -log LOG.compile -cmd_file quartus_compile_lib.cmd
  #
rm -rf simv.daidir
rm -rf libraries/vhdl_libs/altera/*
rm -rf libraries/vhdl_libs/lpm/*
rm -rf libraries/vhdl_libs/sgate/*
rm -rf libraries/vhdl_libs/altera_mf/*
rm -rf libraries/vhdl_libs/altera_lnsim/*
rm -rf libraries/vhdl_libs/fiftyfivenm/*
  #
mkdir -p $LIBDIR/vhdl_libs/altera/64
mkdir -p $LIBDIR/vhdl_libs/lpm/64
mkdir -p $LIBDIR/vhdl_libs/sgate/64
mkdir -p $LIBDIR/vhdl_libs/altera_mf/64
mkdir -p $LIBDIR/vhdl_libs/altera_lnsim/64
mkdir -p $LIBDIR/vhdl_libs/fiftyfivenm/64  
  #
vhdlan $DBG -full64 -nc -work altera $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_syn_attributes.vhd 
vhdlan $DBG -full64 -nc -work altera $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_standard_functions.vhd 
vhdlan $DBG -full64 -nc -work altera $QUARTUS_INSTALL_DIR/eda/sim_lib/alt_dspbuilder_package.vhd 
vhdlan $DBG -full64 -nc -work altera $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_europa_support_lib.vhd 
vhdlan $DBG -full64 -nc -work altera $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_primitives_components.vhd 
vhdlan $DBG -full64 -nc -work altera $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_primitives.vhd
  #
vhdlan $DBG -full64 -nc -work lpm $QUARTUS_INSTALL_DIR/eda/sim_lib/220pack.vhd 
vhdlan $DBG -full64 -nc -work lpm $QUARTUS_INSTALL_DIR/eda/sim_lib/220model.vhd
  #
vhdlan $DBG -full64 -nc -work sgate $QUARTUS_INSTALL_DIR/eda/sim_lib/sgate_pack.vhd 
vhdlan $DBG -full64 -nc -work sgate $QUARTUS_INSTALL_DIR/eda/sim_lib/sgate.vhd
  #
vhdlan $DBG -full64 -nc -work altera_mf $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_mf_components.vhd       
vhdlan $DBG -full64 -nc -work altera_mf $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_mf.vhd
# added clock IP simulation model - synthesis model can't be simulated
#vlogan -full64 -nc -work altera_mf -full64 +v2k $WORKDIR/altera_config_clock_source_endpoint.v
  #
vlogan $DBG -full64 -nc -work altera_lnsim -sverilog $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_lnsim.sv 
vhdlan $DBG -full64 -nc -work altera_lnsim $QUARTUS_INSTALL_DIR/eda/sim_lib/altera_lnsim_components.vhd  
  #
vlogan $DBG -full64 -nc -work fiftyfivenm -sverilog $QUARTUS_INSTALL_DIR/eda/sim_lib/synopsys/fiftyfivenm_atoms_ncrypt.v 
vhdlan $DBG -full64 -nc -work fiftyfivenm $QUARTUS_INSTALL_DIR/eda/sim_lib/fiftyfivenm_atoms.vhd 
vhdlan $DBG -full64 -nc -work fiftyfivenm $QUARTUS_INSTALL_DIR/eda/sim_lib/fiftyfivenm_components.vhd 
  #
fi
#
# now, compile our VHDL code with the Altera VHDL lib defined in synopsys_sim.setup file
#
export PATH=$VCS_HOME/bin:$PATH
#
# define CIFT VHDL code to be compiled
#
if [ $SKIP_COM -eq 0 ]; then
  cd $WORKDIR
  rm -rf simv simv.daidir csrc
  mkdir -p $LIBDIR/vhdl_libs/work
  rm -rf $LIBDIR/vhdl_libs/work/*
  mkdir -p $LIBDIR/vhdl_libs/work/64
  #
vhdlan $DBG -full64 -work work  \
$RTLDIR/bram_constants.vhd \
$RTLDIR/m9k_tdp.vhd \
$RTLDIR/intel_port_constants_pkg.vhd \
$RTLDIR/dp_bram_facade.vhd \
$RTLDIR/march_constants_pkg.vhd \
$RTLDIR/march_generic_pkg.vhd \
$RTLDIR/marchx_pkg.vhd \
$RTLDIR/march_generic.vhd \
$RTLDIR/standard_port_constants_pkg.vhd \
$RTLDIR/tpg_converter.vhd \
$RTLDIR/sp2dp_converter.vhd \
$RTLDIR/ora.vhd \
$RTLDIR/capture.vhd \
$RTLDIR/test_arch.vhd \
$RTLDIR/harness.vhd 
#
vlogan $DBG -full64 -work work  \
$RTLDIR/max10-iowrapper-50MHz.v 
fi
#
#
if [ $SKIP_ELAB -eq 0 ]; then
  #vcs -full64 -lca -l comp.log -t ps top_level 
  vcs $DBG -full64 -lca -l comp.log -debug_access+all -t ps top_level
  #vcs -full64 -lca -t ps top_level
fi
# ----------------------------------------
# simulate
if [ $SKIP_SIM -eq 0 ]; then
  ./simv $RUN_DBG +vcs+finish+100000000
fi
#
#vcs -sverilog -timescale=1ns/1ns -ntb_opts uvm-1.0+rvm +incdir+../sv xbus_tb_top.sv -l comp.log -debug_access+pp  +define+UVM_ON_TOP
