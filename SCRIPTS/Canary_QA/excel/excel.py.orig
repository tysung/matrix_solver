def read_db(db_file):

    ## now, read in $db
    db = {'X_date':[], 'Y_name':[], 'Cells':{}}
    if os.path.exists(db_file):
        with open(db_file) as f:
            db = json.load(f)
        #
        # consolidate {X,Y} elements
        #
        db['X_date'] = list(set(db['X_date']))
        db['X_date'].sort(reverse=True)
        #
        db['Y_name'] = list(set(db['Y_name']))
        db['Y_name'].sort()
        #
    return(db)


def excel_wb_format(workbook):

    fmt_wb = {}
    fmt_wb['bold'] = workbook.add_format( {'bold':1, 'size':16} )
    fmt_wb['size'] = workbook.add_format( {'size':16} )
    fmt_wb['center'] = workbook.add_format( {'align':'center', 'size':16} )
    fmt_wb['header'] = workbook.add_format( {'bold':1, 'size':16, 'align':'center'} )
    # Light red fill with dark red text.
    fmt_wb['format_red'] = workbook.add_format({'bold':1,'color':'red','size':16,'align':'center'})
    fmt_wb['format_blue'] = workbook.add_format({'color':'blue','size':16,'align':'center'})
    return(fmt_wb)


def write_excel_sheet(workbook, worksheet, fmt_wb, db):

    # Expand the first columns so that the date is visible.
    worksheet.set_column( "A:A", 30 )
    worksheet.set_column( "B:K", 20 )
    
    # Write the column headers
    worksheet.write( 'A1', 'Device_Test', fmt_wb['bold'] )
    hd = 'A'
    col = 1
    cell_name = ''
    for X_date in (db['X_date']):
        hd = chr(ord(hd)+1)
        cell_name = hd + str(col)
        worksheet.write( cell_name, X_date, fmt_wb['header'] )
    
    for Y_name in (db['Y_name']):
        col += 1
        hd = 'A'
        cell_name = hd + str(col)
        worksheet.write(cell_name, Y_name, fmt_wb['size'])
        for X_date in (db['X_date']):
            hd = chr(ord(hd)+1)
            cell_name = hd + str(col)
            result = db['Cells'][X_date].get(Y_name, None)

            if result is None:
                worksheet.write(cell_name, 'N.A.', fmt_wb['center'])
            elif 'Fail' in result:
                sheet = Y_name
                range = hd + "2"
                sheet = sheet.replace( ':', '_' )
                worksheet.write_url(cell_name, f'internal:{sheet}!{range}', fmt_wb['format_red'], db['Cells'][X_date][Y_name])
            elif 'New:' in result:
                sheet = Y_name
                range = hd + "2"
                sheet = sheet.replace( ':', '_' )
                worksheet.write_url(cell_name, f'internal:{sheet}!{range}', fmt_wb['format_blue'], db['Cells'][X_date][Y_name])
            elif 'new' == result:
                worksheet.write(cell_name, db['Cells'][X_date][Y_name], fmt_wb['format_blue'])
            elif 'new_fl' == result:
                worksheet.write(cell_name, db['Cells'][X_date][Y_name], fmt_wb['format_red'])
            elif 'none' == result:
                worksheet.write(cell_name, db['Cells'][X_date][Y_name], fmt_wb['format_red'])
            else:
                worksheet.write(cell_name, db['Cells'][X_date][Y_name], fmt_wb['center'])
    
if __name__ == '__main__':
    write_all_excel(qa_golden_dir, today_excel, db_f)
