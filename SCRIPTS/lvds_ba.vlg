`include "/import/projects/FPGA_tools/tools/linux/xilinx/14.7/ISE_DS/ISE/verilog/src/glbl.v"
`timescale 1 ns/1 ps

  module TBX_top_level;
    reg clkin_P;
    reg clkin_N;
    top_level uut (
      .clkin_P (clkin_P),
      .clkin_N (clkin_N)
    );
    initial begin
      clkin_P = 1'b0;
      clkin_N = 1'b1;
      $display("           T cc");
      $display("           i ll");
      $display("           m kk");
      $display("           e ii");
      $display("             nn");
      $display("             __");
      $display("             PN");
      $monitor("%t",$realtime,,clkin_P,clkin_N);
    end

    always begin
       #25 clkin_P = ~clkin_P; 
       clkin_N = ~clkin_N;
    end

    initial begin
    #1000 $stop;
    $display($time, " << Starting the Simulation >>");
    //
    // #1000 $finish;

  end
endmodule
